{
    "dataserver": {
        "port": 13200
    },
    "autodata": {
        "use_dataserver": true,
        "enable_file_output": true,
        "data_dir": "./nanhua_data/",
        "subscribe_tickers": [
            {"code": "PP_NH", "freq": "MIN1"},
            {"code": "RB_NH", "freq": "MIN1"},
            {"code": "I_NH", "freq": "MIN1"},
            {"code": "J_NH", "freq": "MIN1"},
            {"code": "HC_NH", "freq": "MIN1"}
        ]
    },
    "producer": {
        "use_dataserver": true,
        "redis": "redis://valkey:6379",
        "subscribe_tickers": ["AU_NH"]
    },
    "publisher": {
        "kafka": {
            "brokers": ["kafka:9092"],
            "topic": "nanhua_index_data",
            "clientId": "nanhua_index_kafka_producer",
            "logLevel": "INFO"
        },
        "clickhouse": {
            "url": "http://clickhouse:8123",
            "database": "market"
        }
    }
}